#!/usr/bin/env bash
# Mount-safety guard (Dump_Agent_Swarm mesh). Blocks the failure mode where a
# corrupted git index inside a mounted folder stages core source files for
# deletion. Runs on every `git commit`.
#
# Intentional bypass (you really do mean to delete these):  git commit --no-verify

CORE_FILES="game.py ball.py paddle.py settings.py cpu_opponent.py achievements.py start_screen.py test_pong.py"

deleted="$(git diff --cached --name-only --diff-filter=D)"

blocked=""
for f in $CORE_FILES; do
  printf '%s\n' "$deleted" | grep -qx "$f" && blocked="$blocked $f"
done

del_count="$(printf '%s\n' "$deleted" | grep -c .)"

if [ -n "$blocked" ]; then
  echo ""
  echo "  pre-commit BLOCKED: this commit would DELETE core source files:"
  echo "   $blocked"
  echo "  If that is truly intentional, re-run with:  git commit --no-verify"
  echo ""
  exit 1
fi

if [ "$del_count" -ge 5 ]; then
  echo ""
  echo "  pre-commit BLOCKED: this commit removes $del_count tracked files at once."
  echo "  That is the signature of a corrupted mounted-folder index."
  echo "  Run 'git status' and confirm before committing."
  echo "  If it really is intentional:  git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
